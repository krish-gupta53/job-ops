# Job-Ops Backend Environment Variables
# Copy this to .env and fill in your values

# --- REQUIRED ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- DATABASE ---
# SQLite (default, for local dev)
DATABASE_URL=sqlite:///./jobops.db
# PostgreSQL (for production on Render/Cloud Run)
# DATABASE_URL=postgresql://user:password@host:5432/jobops

# --- APP ---
SECRET_KEY=change-this-to-a-random-string
FRONTEND_URL=http://localhost:3000

# --- SCANNING ---
SCAN_INTERVAL_HOURS=12
MAX_JOBS_PER_SCAN=100

# --- MODELS ---
GEMINI_LITE_MODEL=gemini-2.5-flash-lite-preview-06-17
GEMINI_FLASH_MODEL=gemini-2.5-flash-preview-05-20

# --- EMAIL NOTIFICATIONS (optional) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password
