# === REQUIRED ===
GEMINI_API_KEY=your_gemini_api_key_here

# === DATABASE ===
# Local SQLite (default for development)
DATABASE_URL=sqlite:///./jobops.db
# Production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/jobops

# === APP SECURITY ===
SECRET_KEY=change-this-to-a-random-secret-string
FRONTEND_URL=http://localhost:3000

# === AI MODELS ===
# Flash-Lite: cheap bulk tasks (scanning, tagging, dedup)
GEMINI_LITE_MODEL=gemini-2.5-flash-lite-preview-06-17
# Flash: reasoning tasks (scoring, resume tailoring, outreach)
GEMINI_FLASH_MODEL=gemini-2.5-flash-preview-05-20

# === OPTIONAL: Email notifications ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# === OPTIONAL: Rate limiting ===
SCAN_INTERVAL_HOURS=12
MAX_JOBS_PER_SCAN=100
