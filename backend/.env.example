# ============================================================
# Job-Ops Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------------------------------------------------------------
# REQUIRED: Gemini API Key (Free at https://aistudio.google.com/apikey)
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# Database (SQLite for local dev, PostgreSQL for production)
# ------------------------------------------------------------
DATABASE_URL=sqlite:///./jobops.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/jobops

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-string-in-production
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------
# Scanning Schedule
# ------------------------------------------------------------
SCAN_INTERVAL_HOURS=12
MAX_JOBS_PER_SCAN=100

# ------------------------------------------------------------
# Email Notifications (Optional)
# ------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password
